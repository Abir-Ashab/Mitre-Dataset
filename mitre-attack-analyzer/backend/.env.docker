# Docker Environment Configuration
# This file is used when running with Docker Compose

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=False
RELOAD=False

# Model Configuration
BASE_MODEL=Qwen/Qwen2.5-1.5B-Instruct
MODEL_PATH=/app/model
DEVICE=cpu  # Change to 'cuda' if using GPU with nvidia-docker

# MongoDB Configuration (use service name from docker-compose)
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DB_NAME=mitre_attack_logs

# CORS Origins (allow frontend service)
CORS_ORIGINS=http://localhost,http://localhost:80,http://frontend

# Model Parameters
MAX_INPUT_CHARS=6000
MAX_LENGTH_TOKENS=3072
MAX_NEW_TOKENS=512
TEMPERATURE=0.7
TOP_P=0.9
